# Projeto Oficina - exemplo de variaveis de ambiente
#
# Copie este arquivo para .env apenas no ambiente onde a aplicacao sera executada.
# Nunca commite .env real com senhas, tokens, chaves privadas ou connection strings.

# -----------------------------------------------------------------------------
# Frontend Next.js
# -----------------------------------------------------------------------------
# Usado em build time pelo Azure Static Web Apps e pelo frontend local.
# Em ambiente publicado, use a URL publica da API.
#
# Exemplos:
# - Temporario por IP, sem HTTPS: http://SEU_IP_PUBLICO_DA_VM
# - Recomendado com dominio e HTTPS: https://api.seudominio.com
#
# Importante: por ser NEXT_PUBLIC_*, este valor fica embutido no bundle do frontend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001

# -----------------------------------------------------------------------------
# Backend Express
# -----------------------------------------------------------------------------
PORT=4000

# Origens autorizadas para CORS.
# Local:
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001
#
# Azure Static Web Apps:
# CORS_ORIGIN=https://seu-app.azurestaticapps.net
#
# Producao/demo com dominio:
# CORS_ORIGIN=https://app.seudominio.com
CORS_ORIGIN=http://localhost:3001

# Chave usada apenas entre workers e endpoints internos do backend.
# Troque em deploy. Nao use o valor de demo em ambiente publico.
INTERNAL_API_KEY=troque-por-um-valor-longo-e-aleatorio

# Diretorio de uploads locais dentro do container backend.
# O docker-compose monta ./backend/uploads em /app/uploads.
UPLOAD_DIR=/app/uploads

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=oficina_demo
POSTGRES_USER=oficina
POSTGRES_PASSWORD=troque-esta-senha

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
# URL interna usada pelos containers no docker-compose.
RABBITMQ_URL=amqp://rabbitmq:5672

# Fila consumida pelo media-worker.
RABBITMQ_QUEUE=media.uploaded

# -----------------------------------------------------------------------------
# Workers
# -----------------------------------------------------------------------------
# URL interna do backend usada pelos workers dentro da rede Docker.
BACKEND_INTERNAL_URL=http://backend:4000

# -----------------------------------------------------------------------------
# Azure Static Web Apps - configuracao esperada no Portal Azure
# -----------------------------------------------------------------------------
# No recurso Static Web Apps, configure em:
# Settings > Environment variables
#
# Name:
# NEXT_PUBLIC_API_BASE_URL
#
# Value temporario, se a API esta por IP e HTTP:
# http://SEU_IP_PUBLICO_DA_VM
#
# Value recomendado, quando houver dominio + HTTPS:
# https://api.seudominio.com
#
# Depois de alterar esta variavel, rode um novo deploy/build do Static Web Apps.
